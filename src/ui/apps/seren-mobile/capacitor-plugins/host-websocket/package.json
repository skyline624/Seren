{
  "name": "@seren/capacitor-host-websocket",
  "version": "0.1.0",
  "description": "Capacitor plugin exposing a native WebSocket bridge for iOS (URLSessionWebSocketTask) and Android (OkHttp).",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "SerenCapacitorHostWebsocket.podspec"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/core": "catalog:"
  },
  "devDependencies": {
    "@capacitor/android": "catalog:",
    "@capacitor/ios": "catalog:",
    "typescript": "catalog:"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
