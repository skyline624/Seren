{
  "name": "@seren/i18n",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./locales/*": "./src/locales/*"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "vue": "catalog:",
    "vue-i18n": "catalog:"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "description": "Seren i18n factory — wraps vue-i18n with project defaults and bundled fr/en locales."
}
