{
  "name": "@seren/ui-three",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "vue": "catalog:",
    "three": "catalog:",
    "@pixiv/three-vrm": "catalog:",
    "@pixiv/three-vrm-animation": "catalog:",
    "@tresjs/core": "catalog:"
  },
  "devDependencies": {
    "vite": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "vue-tsc": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@types/three": "catalog:"
  }
}