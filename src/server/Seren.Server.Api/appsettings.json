{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SerenDb": "Data Source=seren.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "seren.hub",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Auth": {
    "JwtSecret": "",
    "Issuer": "seren.hub",
    "Audience": "seren.clients",
    "TokenExpirationMinutes": 60,
    "RequireAuthentication": false
  },
  "OpenClaw": {
    "BaseUrl": "http://127.0.0.1:18789",
    "AuthToken": "",
    "DefaultAgentId": "openclaw/default"
  },
  "Audio": {
    "SttProvider": "openai",
    "TtsProvider": "openai",
    "OpenAiBaseUrl": "https://api.openai.com/v1",
    "OpenAiApiKey": "",
    "SttModel": "whisper-1",
    "TtsModel": "tts-1",
    "TtsVoice": "nova"
  },
  "Seren": {
    "WebSocket": {
      "Path": "/ws",
      "KeepAliveIntervalSeconds": 15,
      "ReadTimeoutSeconds": 30
    },
    "RateLimit": {
      "Enabled": true,
      "PermitLimit": 100,
      "WindowSeconds": 10,
      "SegmentsPerWindow": 5,
      "QueueLimit": 0
    },
    "Cors": {
      "AllowedOrigins": [],
      "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "AllowedHeaders": ["Content-Type", "Authorization", "X-Requested-With"],
      "AllowCredentials": true
    }
  }
}