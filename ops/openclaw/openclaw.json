// =============================================================================
// OpenClaw Gateway configuration — JSON5 (comments + trailing commas allowed).
// Mounted read-only at /home/node/.openclaw/openclaw.json inside the container.
//
// Schema reference (zod): src/config/zod-schema.core.ts in openclaw/openclaw.
// `models: []` is valid — OpenClaw discovers Ollama models dynamically at
// runtime via /api/tags. Declare explicit entries only to override cost,
// context window, or reasoning capability.
//
// To add OpenAI / Anthropic, append a block with the schema below AFTER you
// populate the corresponding env var in .env (OpenClaw treats `${FOO}`
// references as hard required secrets at startup, not soft warnings):
//
//   openai: {
//     baseUrl: "https://api.openai.com/v1",
//     apiKey: "${OPENAI_API_KEY}",
//     models: [
//       { id: "gpt-4o",      name: "GPT-4o" },
//       { id: "gpt-4o-mini", name: "GPT-4o mini" },
//     ],
//   },
// =============================================================================
{
  gateway: {
    port: 18789,
    auth: { token: "${OPENCLAW_GATEWAY_TOKEN}" },
    // OpenAI-compatible REST is OFF by default; Seren's OpenClawRestClient
    // posts to POST /v1/chat/completions so we opt in here.
    http: {
      endpoints: {
        chatCompletions: { enabled: true },
      },
    },
  },

  models: {
    providers: {
      // Default: Ollama running on the Docker host (see .env → OLLAMA_BASE_URL).
      // OpenClaw auto-discovers installed models at runtime.
      ollama: {
        baseUrl: "${OLLAMA_BASE_URL}",
        api: "ollama",
        models: [],
      },
    },
  },

  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
      model: {
        // Overridable per request (Seren passes `model` in the body based on
        // the active character's AgentId or the UI Settings override).
        primary: "${OPENCLAW_DEFAULT_MODEL:-ollama/qwen3.5:cloud}",
      },
    },
  },
}
