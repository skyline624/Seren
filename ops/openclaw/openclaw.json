// =============================================================================
// OpenClaw Gateway configuration — JSON5 (comments + trailing commas allowed).
// Mounted read-only at /home/node/.openclaw/openclaw.json inside the container.
//
// Providers whose API key env var is empty stay dormant; OpenClaw only
// surfaces them in /v1/models once the corresponding secret is populated.
// =============================================================================
{
  gateway: {
    port: 18789,
    auth: { token: "${OPENCLAW_GATEWAY_TOKEN}" },
  },

  models: {
    providers: {
      // Default: Ollama running on the Docker host (see .env → OLLAMA_BASE_URL).
      // For a self-hosted container Ollama, point this at http://ollama:11434
      // and add an `ollama` service to docker-compose.yml.
      ollama: {
        baseUrl: "${OLLAMA_BASE_URL}",
        api: "ollama",
      },

      // Optional: enabled only when OPENAI_API_KEY is set in .env.
      openai: {
        apiKey: "${OPENAI_API_KEY}",
      },

      // Optional: enabled only when ANTHROPIC_API_KEY is set in .env.
      anthropic: {
        apiKey: "${ANTHROPIC_API_KEY}",
      },
    },
  },

  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
      model: {
        // Overridable per request (Seren passes `model` in the body based on
        // the active character's AgentId or the UI Settings override).
        primary: "${OPENCLAW_DEFAULT_MODEL:-ollama/qwen3.5:cloud}",
      },
    },
  },
}
