# =============================================================================
# .env.example — Seren stack environment variables
# =============================================================================
# Copy this file to `.env` and fill the required values before running:
#   cp .env.example .env
#   docker compose up -d --build
#
# Never commit the real `.env` to version control (already in .gitignore).
# =============================================================================

# --- OpenClaw Gateway ---------------------------------------------------------
# Shared-secret used by the gateway for HTTP/WebSocket auth. The Seren hub
# sends it as a Bearer token. Must be a strong random string in production.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-strong-random-string

# Bearer token Seren sends to OpenClaw. Defaults to OPENCLAW_GATEWAY_TOKEN
# when unset. Only override if your gateway is exposed through a proxy that
# rewrites the token.
OPENCLAW_AUTH_TOKEN=

# Default model id OpenClaw falls back to when a request doesn't specify one.
# Format: `<provider>/<model>` — e.g. `ollama/qwen3.5:cloud`, `openai/gpt-4o-mini`.
OPENCLAW_DEFAULT_MODEL=ollama/qwen3.5:cloud

# Same value as above, consumed by the Seren hub via
# OpenClaw__DefaultAgentId. Kept as a separate env var for clarity; set
# both to the same string.
DEFAULT_AGENT_ID=ollama/qwen3.5:cloud

# --- LLM provider credentials -------------------------------------------------
# Any provider with an empty key stays dormant. To enable OpenAI /
# Anthropic, drop the keys here and restart the stack.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Ollama -------------------------------------------------------------------
# By default OpenClaw talks to an Ollama running on the Docker host
# (host.docker.internal works on Mac/Win and is mapped to the host gateway
# for Linux in docker-compose.yml). For a containerised Ollama, add an
# `ollama` service in docker-compose.yml and set this to http://ollama:11434.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Seren Hub ----------------------------------------------------------------
# Used to sign JWTs when auth is turned on (Auth__RequireAuthentication=true
# in the compose env block). Leave as-is for local dev; rotate in production.
JWT_SECRET=change-me-to-a-strong-random-string
