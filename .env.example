# =============================================================================
# .env.example — Seren environment variables
# =============================================================================
# Copy this file to .env and customise values before running docker compose.
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# Seren Hub
JWT_SECRET=change-me-to-a-strong-random-string-in-production
OPENCLAW_AUTH_TOKEN=your-openclaw-api-token-here
POSTGRES_PASSWORD=seren

# Override for development
# ASPNETCORE_ENVIRONMENT=Development